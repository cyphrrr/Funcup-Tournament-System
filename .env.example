# BIW Pokal - Environment Variables
# Kopiere diese Datei zu .env und passe die Werte an

# Backend Auth
ADMIN_USER=admin
ADMIN_PASSWORD=pw2026!
API_KEY=biw-n8n-secret-key-change-me
JWT_SECRET=super-secret-jwt-key-change-in-production

# n8n Auth
N8N_USER=admin
N8N_PASSWORD=n8n2026!

# Discord Bot
DISCORD_BOT_TOKEN=dein-bot-token-hier
DISCORD_GUILD_ID=deine-server-id-hier
DASHBOARD_URL=https://your.server

# Discord OAuth2 (für Web-Dashboard Login)
DISCORD_CLIENT_ID=deine-application-id
DISCORD_CLIENT_SECRET=dein-client-secret
DISCORD_REDIRECT_URI=https://your.server/api/auth/discord/callback

# File Upload
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=5242880
CREST_MAX_WIDTH=512
CREST_MAX_HEIGHT=512

# Database
POSTGRES_USER=db_user
POSTGRES_PASSWORD=biw_password_change_me
POSTGRES_DB=db_name
# DATABASE_URL wird automatisch in docker-compose.yml gesetzt
